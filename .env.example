# Database Configuration
# Required for `npm start` in real production mode.
# Leave empty for `npm run dev` or `npm run start:mock`.
DATABASE_URL=postgresql://user:password@localhost:5432/nutri_intel

# Server Configuration
NODE_ENV=development
PORT=5000
# Local-only escape hatch for running the built app without a database.
# Keep this false in real deployments and use `npm run start:mock` when needed.
ALLOW_PRODUCTION_MOCK=false

# Session Configuration
# Use a strong secret with 32+ characters in production.
SESSION_SECRET=change-this-to-a-strong-32-character-secret

# Groq AI API Configuration (get your key from https://console.groq.com)
GROQ_API_KEY=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
GROQ_MODEL=llama-3.1-8b-instant

# Email / SMTP Configuration (leave empty to use Ethereal test emails in dev)
# For production use SendGrid, Mailgun, SES, or any SMTP provider
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@nutri-intel.com

# App URL (used in email links)
APP_URL=https://your-app-domain.com

